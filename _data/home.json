{
  "profile": {
    "name": "Fangchen Yu",
    "role": "Researcher / Builder / Lifelong Learner",
    "avatar": "images/fangchenyu.jpg",
    "vision": "Building science intelligent systems that reason, learn, and interact with the world.",
    "github": {
